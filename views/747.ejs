<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>747 Map - Where Does The 747 Fly - Cargo and Passenger Routes</title>

    <meta name="description"
        content="Discover the destinations and flight paths of the Boeing 747 — both cargo and passenger routes. Filter live routes by category.">

    <link rel="canonical" href="https://www.wheredoesthea380fly.com/747" />
    <meta name="robots" content="index, follow">

    <script src='https://api.tiles.mapbox.com/mapbox-gl-js/v2.14.1/mapbox-gl.js'></script>
    <link href='https://api.tiles.mapbox.com/mapbox-gl-js/v2.14.1/mapbox-gl.css' rel='stylesheet' />
    <link
        href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;700&family=Quicksand:wght@300;400;500;600;700&display=swap"
        rel="stylesheet" />
    <link rel="stylesheet" href="style.css">
    <link rel="icon" href="favicon.webp" type="favicon/webp">

    <style>
        .categoryFilter {
            position: absolute;
            top: 10px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 10;
            background: rgba(255,255,255,0.95);
            padding: 6px 10px;
            border-radius: 8px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.15);
            font-family: 'Quicksand', sans-serif;
        }
        .categoryFilter button {
            border: 1px solid #ccc;
            background: white;
            padding: 6px 14px;
            margin: 0 2px;
            border-radius: 6px;
            cursor: pointer;
            font-size: 14px;
            font-weight: 500;
        }
        .categoryFilter button.active {
            background: #1e88e5;
            color: white;
            border-color: #1e88e5;
        }
        .nav-links {
            position: absolute;
            top: 10px;
            right: 10px;
            z-index: 10;
            background: rgba(255,255,255,0.95);
            padding: 6px 10px;
            border-radius: 8px;
            font-family: 'Quicksand', sans-serif;
        }
        .nav-links a {
            color: #1e88e5;
            text-decoration: none;
            font-weight: 500;
        }
    </style>
</head>

<body>
    <script src="https://unpkg.com/@turf/turf@6/turf.min.js"></script>

    <div class="categoryFilter">
        <button id="filter-all" class="active">All</button>
        <button id="filter-passenger">Passenger</button>
        <button id="filter-cargo">Cargo</button>
    </div>

    <div class="nav-links">
        <a href="/">← A380 map</a>
    </div>

    <div id="map"></div>
    <div id="tooltip"></div>
    <div id="lineTooltip" class="mapboxgl-lineTooltip"></div>

    <div class="seodata">
        <h1>Boeing 747 Flight Paths and Destination Map</h1>
        <h2>Cargo and Passenger 747 Routes Worldwide</h2>
        <p>Filter routes by cargo or passenger operations. Live data from FR24 and ADS-B.</p>
    </div>

    <script type="module" src="747.js"></script>
</body>

</html>
